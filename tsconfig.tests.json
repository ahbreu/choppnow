{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": ".test-dist",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["tests/**/*.ts", "src/data/**/*.ts", "src/services/**/*.ts"],
  "exclude": ["dist", "node_modules", "src/pages/**/*", "src/components/**/*", "src/hooks/**/*", ".test-dist"]
}
