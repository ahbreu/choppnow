# Copy this file to `.env` and fill your own values.
# Expo will expose EXPO_PUBLIC_* vars to the app at runtime.

EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional: backend base URL for remote auth/session.
# Falls back to orders/catalog base URLs when omitted.
EXPO_PUBLIC_AUTH_API_BASE_URL=
EXPO_PUBLIC_AUTH_API_TIMEOUT_MS=4500

# Local validation backend examples:
# Same machine: http://127.0.0.1:4010
# Another device on the same network: http://SEU_IP_LOCAL:4010
# EXPO_PUBLIC_AUTH_API_BASE_URL=http://127.0.0.1:4010

# Catalog runtime environment (`development`, `stage`, `production`).
EXPO_PUBLIC_APP_ENV=development

# Optional: backend base URL for catalog snapshot/inventory sync.
# Example: http://localhost:3001
EXPO_PUBLIC_CATALOG_API_BASE_URL=
# EXPO_PUBLIC_CATALOG_API_BASE_URL=http://127.0.0.1:4010

# Optional: backend base URL for orders/create/list/status.
# Falls back to EXPO_PUBLIC_CATALOG_API_BASE_URL when omitted.
EXPO_PUBLIC_ORDERS_API_BASE_URL=
# EXPO_PUBLIC_ORDERS_API_BASE_URL=http://127.0.0.1:4010

# Optional: catalog API timeout controls (milliseconds).
EXPO_PUBLIC_CATALOG_API_TIMEOUT_MS=4500
EXPO_PUBLIC_CATALOG_SNAPSHOT_TIMEOUT_MS=3000
EXPO_PUBLIC_CATALOG_SNAPSHOT_RETRY_ATTEMPTS=2
EXPO_PUBLIC_CATALOG_SNAPSHOT_RETRY_DELAY_MS=450
EXPO_PUBLIC_CATALOG_SYNC_TIMEOUT_MS=6000

# Optional: inventory sync retry/backoff controls.
EXPO_PUBLIC_CATALOG_SYNC_RETRY_ATTEMPTS=2
EXPO_PUBLIC_CATALOG_SYNC_RETRY_DELAY_MS=700
EXPO_PUBLIC_CATALOG_SYNC_RETRY_MULTIPLIER=1.7
EXPO_PUBLIC_CATALOG_SYNC_RETRY_MAX_DELAY_MS=3000

# Optional: orders API timeout controls (milliseconds).
EXPO_PUBLIC_ORDERS_API_TIMEOUT_MS=4500

# Optional: runtime status chip auto-refresh interval (milliseconds).
EXPO_PUBLIC_CATALOG_STATUS_REFRESH_MS=
